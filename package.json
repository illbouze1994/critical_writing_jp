{
  "name": "critical-writing-jp",
  "displayName": "CriticalWritingJp",
  "description": "学術・批評文章の執筆支援拡張機能",
  "version": "1.0.0",
  "publisher": "illbouze",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/your-organization/critical-writing-jp.git"
  },
  "bugs": {
    "url": "https://github.com/your-organization/critical-writing-jp/issues"
  },
  "homepage": "https://github.com/your-organization/critical-writing-jp#readme",
  "engines": {
    "vscode": "^1.99.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "japanese",
    "writing",
    "academic",
    "analysis"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:markdown",
    "onLanguage:plaintext",
    "onCommand:criticalWritingJp.togglePanel",
    "onCommand:criticalWritingJp.enableLLM",
    "onCommand:criticalWritingJp.configureGoogleBooksKey",
    "onCommand:criticalWritingJp.runKeywordNow",
    "onCommand:criticalWritingJp.validateCitationStyle",
    "onCommand:criticalWritingJp.fixStyleIssues"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/**",
    "webview-assets/**",
    "scripts/**",
    "README*",
    "LICENSE*",
    "package.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "criticalWritingJp.togglePanel",
        "title": "CriticalWritingJp: Toggle Panel"
      },
      {
        "command": "criticalWritingJp.enableLLM",
        "title": "CriticalWritingJp: Enable LLM (Consent)"
      },
      {
        "command": "criticalWritingJp.configureGoogleBooksKey",
        "title": "CriticalWritingJp: Configure Google Books API Key"
      },
      {
        "command": "criticalWritingJp.runKeywordNow",
        "title": "CriticalWritingJp: Re-Analyze Now"
      },
      {
        "command": "criticalWritingJp.validateCitationStyle",
        "title": "CriticalWritingJp: Validate Citation Style"
      },
      {
        "command": "criticalWritingJp.fixStyleIssues",
        "title": "CriticalWritingJp: Apply Style Fixes"
      }
    ],
    "configuration": {
      "title": "CriticalWritingJp",
      "properties": {
        "criticalWritingJp.counting.threshold.min": {
          "type": "number",
          "minimum": 0,
          "default": 200,
          "description": "段落の最小文字数しきい値",
          "order": 1
        },
        "criticalWritingJp.counting.threshold.max": {
          "type": "number",
          "minimum": 1,
          "default": 800,
          "description": "段落の最大文字数しきい値",
          "order": 2
        },
        "criticalWritingJp.roi.weights": {
          "type": "object",
          "properties": {
            "w1": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "w2": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "w3": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "w4": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "required": [
            "w1",
            "w2",
            "w3",
            "w4"
          ],
          "default": {
            "w1": 0.35,
            "w2": 0.35,
            "w3": 0.15,
            "w4": 0.15
          },
          "description": "ROI計算の重み係数",
          "order": 20
        },
        "criticalWritingJp.citations.googleBooks.apiKey": {
          "type": "string",
          "default": "",
          "description": "Google Books APIキー",
          "order": 40
        },
        "criticalWritingJp.llm.enabled": {
          "type": "boolean",
          "default": false,
          "description": "LLM評価機能の有効化",
          "order": 50
        },
        "criticalWritingJp.llm.backend": {
          "type": "string",
          "enum": [
            "wasm",
            "node"
          ],
          "default": "wasm",
          "description": "LLMバックエンド種別",
          "order": 51
        },
        "criticalWritingJp.llm.modelPath": {
          "type": "string",
          "default": "",
          "description": "LLMモデルファイルパス",
          "order": 52
        },
        "criticalWritingJp.style.dictionaryPath": {
          "type": "string",
          "default": "",
          "description": "スタイル辞書ファイルパス",
          "order": 60
        },
        "criticalWritingJp.citationStyle.active": {
          "type": "string",
          "enum": [
            "デフォルト",
            "generic.ja.v1"
          ],
          "enumDescriptions": [
            "デフォルト: 著者名、『書籍名』、出版社、出版年、30―90頁",
            "汎用日本語スタイル v1"
          ],
          "default": "デフォルト",
          "description": "アクティブな引用スタイル",
          "order": 70
        },
        "criticalWritingJp.citationStyle.packPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "引用スタイルパックのパス一覧",
          "order": 71
        },
        "criticalWritingJp.citationStyle.autoFix.enabled": {
          "type": "boolean",
          "default": false,
          "description": "引用スタイル自動修正の有効化",
          "order": 72
        },
        "criticalWritingJp.citationStyle.diffMode": {
          "type": "string",
          "enum": [
            "unified",
            "side-by-side"
          ],
          "default": "unified",
          "description": "差分表示モード",
          "order": 73
        },
        "criticalWritingJp.privacy.anonymizeBeforeSend": {
          "type": "boolean",
          "default": true,
          "description": "外部送信前の匿名化処理",
          "order": 80
        },
        "criticalWritingJp.performance.maxWorkers": {
          "type": "number",
          "minimum": 1,
          "maximum": 4,
          "default": 2,
          "description": "最大ワーカー数",
          "order": 90
        },
        "criticalWritingJp.ui.preview.headChars": {
          "type": "number",
          "minimum": 10,
          "maximum": 120,
          "default": 40,
          "description": "プレビュー表示文字数",
          "order": 100
        }
      }
    }
  },
  "scripts": {
    "build": "node scripts/build.js",
    "build:dev": "node scripts/build.js --dev",
    "watch": "node scripts/build.js --watch",
    "build-and-install": "node scripts/build-and-install.js",
    "build-and-install:skip-cleanup": "node scripts/build-and-install.js --skip-cleanup",
    "build-and-install:skip-build": "node scripts/build-and-install.js --skip-build",
    "build-and-install:skip-install": "node scripts/build-and-install.js --skip-install",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest --projects jest.config.js webview-ui/jest.config.js",
    "test:unit": "jest --projects jest.config.js webview-ui/jest.config.js --coverage",
    "test:watch": "jest --projects jest.config.js webview-ui/jest.config.js --watch",
    "test:coverage": "jest --coverage --coverageReporters=text-lcov",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.9",
    "eslint": "^9.0.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@tabler/core": "^1.4.0",
    "@tabler/icons-react": "^3.34.1",
    "@types/chart.js": "^2.9.41",
    "chart.js": "^4.5.0",
    "joyo-kanji": "^0.2.1",
    "kuromoji": "^0.1.2",
    "python-shell": "^5.0.0",
    "react-feather": "^2.0.10",
    "recharts": "^3.1.2",
    "textlint-rule-ja-joyo-or-jinmeiyo-kanji": "^1.0.3",
    "textlint-rule-preset-jtf-style": "^3.0.2"
  }
}
